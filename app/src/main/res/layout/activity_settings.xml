<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Праг на детекция ──────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_confidence"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hint_confidence"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <SeekBar
                android:id="@+id/seekbar_confidence"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/tv_confidence_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0.50"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

        </LinearLayout>

        <!-- ── GPS интервал ──────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_gps_interval"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:paddingTop="20dp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/et_gps_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="2000"
            android:inputType="number"
            android:importantForAutofill="no" />

        <!-- ── URL на сървъра ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_server_url"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:paddingTop="20dp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/et_server_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://192.168.1.100:8080/"
            android:inputType="textUri"
            android:importantForAutofill="no" />

        <!-- ── Бутон за запазване ─────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save"
            android:layout_marginTop="28dp" />

    </LinearLayout>
</ScrollView>
